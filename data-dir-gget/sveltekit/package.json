{
  "name": "eu-logs",
  "version": "1.0.0",
  "description": "Log monitoring and management application",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node --transpile-only' src/server.ts",
    "lint": "eslint . --ignore-pattern 'playwright-report/**'",
    "lint:fix": "eslint . --fix --ignore-pattern 'playwright-report/**'",
    "clean": "rm -rf dist",
    "test": "jest --config=jest.config.cjs --runInBand",
    "test:e2e": "jest --config=jest.config.cjs --runInBand",
    "precommit": "npm run build && npm run lint:fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "compression": "^1.8.0",
    "dotenv": "^16.5.0",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@playwright/test": "^1.52.0",
    "@types/compression": "^1.7.5",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.1",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.1",
    "@types/supertest": "^6.0.3",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^9.25.0",
    "eslint-plugin-n": "^17.17.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
