# env.template
#
# Template for environment variables used by scripts in this repository.
# Copy this file to .env and fill in your actual values.
#
# Usage:
#   cp env.template .env
#   # Edit .env with your actual API keys and configuration
#
# Note: .env is gitignored to keep secrets safe.

# =============================================================================
# API Keys
# =============================================================================

# Gemini API Key (used by gem.sh)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic API Key (used by various AI tools)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (used by various AI tools)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google API Key (alternative to GEMINI_API_KEY)
GOOGLE_API_KEY=your_google_api_key_here

# =============================================================================
# Google Cloud / Vertex AI Configuration
# =============================================================================
# Note: gem.sh unsets these to use direct API instead of Vertex AI

# VERTEXAI_PROJECT=your_gcp_project_id
# VERTEXAI_LOCATION=your_gcp_location
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# GOOGLE_CLOUD_LOCATION=your_gcp_location
